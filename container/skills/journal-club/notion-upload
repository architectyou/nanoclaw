#!/bin/bash
# notion-upload: Upload markdown content to a Notion page
# Requires NOTION_API_KEY and NOTION_DATABASE_ID environment variables
set -euo pipefail

usage() {
  echo "Usage:"
  echo "  notion-upload <file.md> [title]    Upload markdown file as a new Notion page"
  echo "  notion-upload check                Check Notion API connection"
  exit 1
}

[ $# -lt 1 ] && usage

NOTION_API_KEY="${NOTION_API_KEY:-}"
NOTION_DATABASE_ID="${NOTION_DATABASE_ID:-}"

if [ -z "$NOTION_API_KEY" ]; then
  echo "Error: NOTION_API_KEY not set. Configure it in container environment." >&2
  exit 1
fi

case "$1" in
  check)
    curl -s -o /dev/null -w "%{http_code}" \
      "https://api.notion.com/v1/users/me" \
      -H "Authorization: Bearer $NOTION_API_KEY" \
      -H "Notion-Version: 2022-06-28" | {
        read -r code
        if [ "$code" = "200" ]; then
          echo "Notion API: connected"
        else
          echo "Notion API: failed (HTTP $code)"
          exit 1
        fi
      }
    ;;
  *)
    FILE="$1"
    [ ! -f "$FILE" ] && { echo "Error: File not found: $FILE"; exit 1; }
    TITLE="${2:-$(basename "$FILE" .md)}"
    CONTENT=$(cat "$FILE")

    # Split content into blocks (Notion API limit: 2000 chars per block)
    # Simple approach: split by double newlines (paragraphs)
    python3 -c "
import json, sys, re

content = open('$FILE').read()
title = '$TITLE'
database_id = '$NOTION_DATABASE_ID'

# Split into paragraphs
paragraphs = [p.strip() for p in re.split(r'\n{2,}', content) if p.strip()]

children = []
for p in paragraphs:
    # Detect headings
    if p.startswith('## '):
        children.append({
            'object': 'block', 'type': 'heading_2',
            'heading_2': {'rich_text': [{'type': 'text', 'text': {'content': p[3:]}}]}
        })
    elif p.startswith('# '):
        children.append({
            'object': 'block', 'type': 'heading_1',
            'heading_1': {'rich_text': [{'type': 'text', 'text': {'content': p[2:]}}]}
        })
    elif p.startswith('- '):
        for item in p.split('\n'):
            if item.startswith('- '):
                children.append({
                    'object': 'block', 'type': 'bulleted_list_item',
                    'bulleted_list_item': {'rich_text': [{'type': 'text', 'text': {'content': item[2:]}}]}
                })
    elif p.startswith('\`\`\`'):
        lang = p.split('\n')[0].replace('\`\`\`', '').strip()
        code = '\n'.join(p.split('\n')[1:]).rstrip('\`\`\`').strip()
        children.append({
            'object': 'block', 'type': 'code',
            'code': {'rich_text': [{'type': 'text', 'text': {'content': code[:2000]}}], 'language': lang or 'plain text'}
        })
    else:
        # Truncate to Notion's 2000 char limit per block
        for i in range(0, len(p), 2000):
            children.append({
                'object': 'block', 'type': 'paragraph',
                'paragraph': {'rich_text': [{'type': 'text', 'text': {'content': p[i:i+2000]}}]}
            })

payload = {
    'parent': {'database_id': database_id} if database_id else {'type': 'page_id'},
    'properties': {'title': {'title': [{'text': {'content': title}}]}},
    'children': children[:100]  # Notion limit: 100 blocks per request
}

print(json.dumps(payload))
" | curl -s -X POST "https://api.notion.com/v1/pages" \
      -H "Authorization: Bearer $NOTION_API_KEY" \
      -H "Notion-Version: 2022-06-28" \
      -H "Content-Type: application/json" \
      -d @- | python3 -c "
import json, sys
r = json.load(sys.stdin)
if 'id' in r:
    print(f\"Uploaded to Notion: https://notion.so/{r['id'].replace('-', '')}\")
else:
    print(f\"Error: {r.get('message', 'Unknown error')}\", file=sys.stderr)
    sys.exit(1)
"
    ;;
esac
